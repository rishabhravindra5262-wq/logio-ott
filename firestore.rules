rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ==========================================
    // 🛡️ GLOBAL SAFETY HELPERS
    // ==========================================
    
    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    // Global Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // ==========================================
    // 🎥 SERIES COLLECTION
    // ==========================================
    
    match /series/{seriesId} {
      allow get: if isValidId(seriesId);
      allow list: if true; // Public marketplace
      
      // Validation for Series (Server-side writes bypass this, but locked for client)
      function isValidSeries(data) {
        return data.title is string && data.title.size() > 0 && data.title.size() <= 200 &&
               data.description is string && data.description.size() <= 2000 &&
               data.horizontalThumbnail is string &&
               data.verticalThumbnail is string &&
               data.keys().hasAll(['id', 'title', 'description', 'createdAt']) &&
               data.keys().size() <= 15; // Strict size check
      }

      allow write: if false; // Locked to Server SDK only
    }

    // ==========================================
    // 🎞️ VIDEOS (EPISODES)
    // ==========================================
    
    match /videos/{videoId} {
      allow get: if isValidId(videoId);
      allow list: if true;
      
      function isValidVideo(data) {
        return data.seriesId is string &&
               data.videoUrl is string &&
               data.episodeNumber is number &&
               data.keys().hasAll(['id', 'seriesId', 'videoUrl', 'episodeNumber']) &&
               data.keys().size() <= 15;
      }

      allow write: if false; // Locked to Server SDK only
    }

    // ==========================================
    // 📊 APP CONFIG & STATS
    // ==========================================
    
    match /config/{docId} {
      allow read: if true;
      allow write: if false;
    }

    match /stats/{docId} {
      allow read: if true;
      allow write: if false;
    }
  }
}
